{
  "name": "herdr-f1",
  "version": "0.1.0",
  "type": "module",
  "description": "Herdr F1 — watch your coding agents race in the browser",
  "bin": {
    "herdr-f1": "bin/herdr-f1.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "herdr-plugin.toml"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build && ncc build src/server/cli.ts -o dist/server --target es2022 --license licenses.txt",
    "start": "node bin/herdr-f1.js",
    "prepack": "npm run build",
    "dev:server": "tsx src/server/cli.ts start",
    "dev:web": "vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@vercel/ncc": "^0.44.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "ws": "^8.21.1"
  }
}
