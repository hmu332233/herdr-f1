{
  "name": "herdr-f1",
  "version": "0.1.0",
  "type": "module",
  "description": "Herdr F1 — watch your coding agents race in the browser",
  "bin": { "herdr-f1": "bin/herdr-f1.js" },
  "files": ["bin", "dist", "README.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node bin/herdr-f1.js",
    "prepack": "npm run build",
    "dev:server": "tsx src/server/cli.ts start --no-open",
    "dev:web": "vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": { "ws": "^8.18.0" },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
